OPENAI_API_KEY=sk-proj-...

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=EAAaxGK...        # Permanent token van Meta app
WHATSAPP_PHONE_NUMBER_ID=              # Phone Number ID (niet het nummer zelf)
WHATSAPP_VERIFY_TOKEN=                 # Zelf te kiezen geheime string voor webhook verificatie
WHATSAPP_APP_SECRET=                   # App Secret (kort hex-getal, voor HMAC verificatie)

# Interne beveiliging
INTERNAL_API_KEY=                      # Willekeurige sterke string voor /api/notifications/*

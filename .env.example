# Multi-tenant Database Configuratie
TENANT_ID=daan
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Alternatieve databases voor meerdere tenants
# DATABASE_URL_DAAN=postgresql://daan_user:pass@host:5432/daan_db
# DATABASE_URL_BROER=postgresql://broer_user:pass@host:5432/broer_db

# API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Multi-tenant Authenticatie
TENANT_ID=daan

# Daan's credentials
AUTH_ADMIN_PASSWORD_HASH_DAAN=
AUTH_DEVICE_PIN_HASH_DAAN=

# Broer's credentials  
AUTH_ADMIN_PASSWORD_HASH_BROER=
AUTH_DEVICE_PIN_HASH_BROER=

# Fallback (backward compatibility)
AUTH_ADMIN_PASSWORD_HASH=
AUTH_DEVICE_PIN_HASH=

# Session configuratie
AUTH_IDLE_TIMEOUT_MINUTES=30
AUTH_ABSOLUTE_TIMEOUT_HOURS=168
AUTH_TOUCH_INTERVAL_SECONDS=300
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_BLOCK_MINUTES=15
AUTH_TRUSTED_DEVICE_DAYS=30

# System
CRON_SECRET=
INTERNAL_API_KEY=

# Telegram Integratie
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
